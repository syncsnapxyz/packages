{
  "name": "@syncsnap/react",
  "version": "1.0.2",
  "description": "Syncsnap client SDK for React",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles": "./dist/styles/globals.css",
    "./theme": "./dist/theme.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "tsup src/index.tsx --dts --format esm --out-dir dist --clean --sourcemap && node scripts/copy-theme.cjs",
    "publish": "npm publish --access public",
    "publish:ci": "npm publish --provenance --access public",
    "link": "npm run build && npm link",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/syncsnapxyz/packages.git",
    "directory": "react"
  },
  "homepage": "https://github.com/syncsnapxyz/packages/react#readme",
  "bugs": {
    "url": "https://github.com/syncsnapxyz/packages/react/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "syncsnap",
    "react",
    "sdk",
    "upload",
    "file-sync"
  ],
  "license": "MIT",
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "qrcode": "^1.5.3",
    "radix-ui": "^1.4.3",
    "shadcn": "^3.8.5",
    "tailwind-merge": "^2.6.1",
    "tw-animate-css": "^1.4.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "tailwindcss": "^3.0.0 || ^4.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.13",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "tsup": "^8.0.1",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0"
  }
}
