{
	"name": "syncsnap",
	"version": "1.0.1",
	"description": "Syncsnap server SDK for Node/Next.js",
	"type": "module",
	"main": "dist/index.js",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./next": {
			"types": "./dist/next.d.ts",
			"default": "./dist/next.js"
		}
	},
	"files": [
		"dist"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/syncsnap/syncsnap.git",
		"directory": "packages/syncsnap-server"
	},
	"keywords": [
		"syncsnap",
		"server",
		"sdk",
		"next.js",
		"api",
		"file-sync"
	],
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^25.2.2",
		"tsup": "^8.0.1",
		"typescript": "^5.4.0",
		"vitest": "^2.1.0"
	},
	"scripts": {
		"build": "tsup src/index.ts src/next.ts --dts --format esm --out-dir dist --clean --sourcemap",
		"publish": "npm publish --provenance --access public",
		"link": "npm run build && npm link",
		"prepublishOnly": "npm run build",
		"test": "vitest run",
		"test:watch": "vitest"
	}
}
