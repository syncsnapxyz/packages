{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {"outputs": ["dist/**"], "dependsOn": []},
    "publish": {"dependsOn": ["build"], "outputs": []},
    "publish:ci": {
      "dependsOn": ["build"],
      "outputs": [],
      "passThroughEnv": ["ACTIONS_ID_TOKEN_REQUEST_URL", "ACTIONS_ID_TOKEN_REQUEST_TOKEN"]
    },
    "lint": {"outputs": []},
    "lint:fix": {"outputs": []},
    "format": {"outputs": []},
    "format:check": {"outputs": []}
  }
}
